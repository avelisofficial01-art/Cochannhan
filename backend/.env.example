# ─── Database ──────────────────────────────────────────
# Render PostgreSQL (managed): copy from Render Dashboard
# Local dev: connect to your local PostgreSQL
DATABASE_URL=postgresql://co_dao:co_dao_dev@localhost:5432/co_dao

# ─── Redis (Optional) ─────────────────────────────────
# Server runs without Redis if unavailable
# Local dev or external Redis (Upstash/Redis Cloud)
REDIS_URL=redis://localhost:6379

# ─── Auth ─────────────────────────────────────────────
JWT_SECRET=change_me_in_production_use_64char_random
JWT_REFRESH_SECRET=change_me_refresh_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Server ───────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── CORS (Local Dev Only) ────────────────────────────
# In production, backend serves frontend → same origin → no CORS needed.
# In local dev, frontend runs on port 5173 via Vite proxy.
CORS_ORIGIN=http://localhost:5173

# ─── Render Deployment ────────────────────────────────
# These are set automatically by render.yaml:
#   DATABASE_URL  → Render PostgreSQL internal URL
#   PORT           → Render assigns automatically
#   NODE_ENV       → production
#   JWT_SECRET     → auto-generated by Render
#
# No manual env var setup needed — just push to Render!
